# Copy this file to .env and fill in your values

# Your backend API base URL (used in src/api/register.js)
VITE_API_URL=https://api.yoursite.com

# EmailJS (used in src/api/contact.js - Option A)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Formspree form ID (used in src/api/contact.js - Option B)
VITE_FORMSPREE_ID=
